# Sincronización (opcional). Sin estas variables, la app funciona 100% local.
# Copia este archivo a `.env.local` y rellénalo con los datos de tu app web de
# Firebase (Configuración del proyecto → Tus apps → SDK de Firebase → Config).
# En Netlify, defínelas en Site settings → Environment variables.
# Estos valores son públicos por diseño (van en el cliente); la seguridad la dan
# las reglas de Firestore y la clave de hogar.
VITE_FIREBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_APP_ID=1:xxxxxxxxxxx:web:xxxxxxxxxxxxxxxx

# Sugerencias de recetas con IA (opcional, gratis con Google Gemini).
# OJO: SIN prefijo VITE_ → es una clave de SERVIDOR (solo la usa la función de
# Netlify, nunca el navegador). Consíguela gratis en https://aistudio.google.com/apikey
# y ponla en Netlify → Environment variables. En local necesitas `netlify dev`.
GEMINI_API_KEY=tu-clave-de-gemini
